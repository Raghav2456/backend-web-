datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum FeedbackStatus {
  NEW
  TRIAGED
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

enum FeedbackSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model User {
  id           String            @id @default(uuid())
  name         String?
  email        String            @unique
  image        String?
  passwordHash String?
  globalRole   Role              @default(VIEWER)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  createdFeedbacks FeedbackItem[] @relation("CreatedBy")
  assignedFeedbacks FeedbackItem[] @relation("AssignedTo")
}

model Workspace {
  id           String            @id @default(uuid())
  name         String
  slug         String            @unique
  description  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  members      WorkspaceMember[]
  feedbackItems FeedbackItem[]
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  role        Role
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model FeedbackItem {
  id          String            @id @default(uuid())
  workspaceId String
  title       String
  content     String
  category    String
  source      String
  status      FeedbackStatus    @default(NEW)
  sentiment   FeedbackSentiment @default(NEUTRAL)
  priority    Int               @default(2)
  customer    String?
  createdById String?
  assigneeId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User?             @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignee    User?             @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
}
